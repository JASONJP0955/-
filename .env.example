OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-5-mini
STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
JAVA_BACKEND_URL=http://127.0.0.1:8080

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional Google Speech-to-Text fallback.
# Set STT_PROVIDER=google and provide either GOOGLE_SPEECH_ACCESS_TOKEN or GOOGLE_SPEECH_API_KEY.
GOOGLE_SPEECH_ACCESS_TOKEN=
GOOGLE_SPEECH_API_KEY=
GOOGLE_SPEECH_MODEL=latest_short
